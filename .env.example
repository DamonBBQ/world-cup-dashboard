# API-FOOTBALL (api-football.com)
# 注册地址：https://api-football.com/register
# 免费版：100 requests/day
API_FOOTBALL_KEY=your_api_football_key_here

# football-data.org
# 注册地址：https://www.football-data.org/client/register
# 免费版：10 requests/min
FOOTBALL_DATA_KEY=your_football_data_key_here

# 数据源选择（api-football 或 football-data）
LIVE_SCORE_PROVIDER=api-football

# 其他环境变量
# VITE_* 开头的环境变量会暴露到前端（不要放敏感信息）
